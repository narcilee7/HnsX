# Files generated by `hnsx run` / `hnsx eval` — never commit these.
# They contain session traces and eval outputs that may include
# sensitive data (user prompts, tool calls, costs).

# Local eval runs (JSONL)
.eval-cache/
eval-runs/

# Local run outputs
.runs/

# Editor / OS junk
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local secrets — keep them out of git even if you commit domain.yaml.
# Put real keys in `~/.config/hnsx/secrets.yaml` or your secret manager.
.secrets/
*.local.yaml
.env
.env.local

# Per-domain scratch
notes.md
scratch/

