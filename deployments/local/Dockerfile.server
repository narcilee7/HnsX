FROM golang:1.26-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags "-s -w" -o /bin/hnsx-server ./cmd/hnsx-server

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/hnsx-server /usr/local/bin/hnsx-server
EXPOSE 50051 50061
ENTRYPOINT ["hnsx-server", "server"]
